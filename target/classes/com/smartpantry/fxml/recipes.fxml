<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      spacing="0"
      prefWidth="390"
      prefHeight="844"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml">

    <VBox alignment="CENTER_LEFT"
          spacing="6"
          prefHeight="120"
          prefWidth="390"
          style="-fx-background-color: #2f6b4f;">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="Recipes"
               style="-fx-text-fill: white; -fx-font-size: 28px;" />

        <Label text="Based on your pantry"
               style="-fx-text-fill: white; -fx-font-size: 14px;" />

    </VBox>

    <ScrollPane fitToWidth="true"
                prefWidth="390"
                prefHeight="660"
                style="-fx-background-color: transparent;">

        <VBox spacing="18" style="-fx-padding: 15;">

            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-padding: 10;">

                <Label text="Recipe Image"
                       alignment="CENTER"
                       prefWidth="320"
                       prefHeight="110"
                       style="-fx-background-color: #d9d9d9; -fx-text-fill: #666666;" />

                <Label text="Tomato Omelette"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <HBox spacing="10">
                    <Label text="20 min"/>
                    <Label text="Easy"/>
                    <Label text="100% Match"
                           style="-fx-text-fill: green; -fx-font-weight: bold;"/>
                </HBox>

                <Button text="View Recipe"
                        prefWidth="320"
                        style="-fx-background-color: #2f6b4f; -fx-text-fill: white;"/>

            </VBox>

            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-padding: 10;">

                <Label text="Recipe Image"
                       alignment="CENTER"
                       prefWidth="320"
                       prefHeight="110"
                       style="-fx-background-color: #d9d9d9; -fx-text-fill: #666666;" />

                <Label text="Pasta Tomato Sauce"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <HBox spacing="10">
                    <Label text="25 min"/>
                    <Label text="Easy"/>
                    <Label text="90% Match"
                           style="-fx-text-fill: green; -fx-font-weight: bold;"/>
                </HBox>

                <Button text="View Recipe"
                        prefWidth="320"
                        style="-fx-background-color: #2f6b4f; -fx-text-fill: white;"/>

            </VBox>

            <VBox spacing="8"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-padding: 10;">

                <Label text="Recipe Image"
                       alignment="CENTER"
                       prefWidth="320"
                       prefHeight="110"
                       style="-fx-background-color: #d9d9d9; -fx-text-fill: #666666;" />

                <Label text="Tomato Soup"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <HBox spacing="10">
                    <Label text="30 min"/>
                    <Label text="Easy"/>
                    <Label text="85% Match"
                           style="-fx-text-fill: green; -fx-font-weight: bold;"/>
                </HBox>

                <Button text="View Recipe"
                        prefWidth="320"
                        style="-fx-background-color: #2f6b4f; -fx-text-fill: white;"/>

            </VBox>

        </VBox>

    </ScrollPane>

    <HBox alignment="CENTER" spacing="15" prefHeight="64">
        <Button text="Pantry" prefWidth="70"/>
        <Button text="Recipes" prefWidth="70"/>
        <Button text="+" prefWidth="55"
                style="-fx-background-color: #2f6b4f; -fx-text-fill: white; -fx-font-size: 20px;"/>
        <Button text="Shopping" prefWidth="80"/>
        <Button text="Profile" prefWidth="70"/>
    </HBox>

</VBox>