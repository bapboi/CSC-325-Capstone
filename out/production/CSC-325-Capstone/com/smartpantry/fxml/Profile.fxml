<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" prefWidth="400" prefHeight="700"
      style="-fx-background-color: #f5f7f3;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smartpantry.controllers.ProfileController">
    <padding>
        <Insets top="35" right="30" bottom="35" left="30" />
    </padding>

    <Label text="Profile" style="-fx-font-size: 26px; -fx-font-weight: bold;" />

    <GridPane hgap="12" vgap="12">
        <Label text="Email:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <Label fx:id="emailLabel" text="demo@smartpantry.com" GridPane.rowIndex="0" GridPane.columnIndex="1" />
        <Label text="Pantry Items:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <Label fx:id="pantryCountLabel" text="0" GridPane.rowIndex="1" GridPane.columnIndex="1" />
        <Label text="Saved Recipes:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <Label fx:id="savedRecipeCountLabel" text="0" GridPane.rowIndex="2" GridPane.columnIndex="1" />
    </GridPane>

    <HBox spacing="8">
        <Button text="Settings" onAction="#handleSettings" prefWidth="105" />
        <Button text="Log Out" onAction="#handleLogout" prefWidth="105" />
        <Button text="Back" onAction="#handleBackToPantry" prefWidth="105" />
    </HBox>
</VBox>
