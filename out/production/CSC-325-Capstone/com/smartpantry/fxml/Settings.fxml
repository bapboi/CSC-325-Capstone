<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16" prefWidth="400" prefHeight="700"
      style="-fx-background-color: #f5f7f3;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smartpantry.controllers.SettingsController">
    <padding>
        <Insets top="35" right="30" bottom="35" left="30" />
    </padding>

    <Label text="Settings" style="-fx-font-size: 26px; -fx-font-weight: bold;" />
    <CheckBox fx:id="notificationsCheckBox" text="Enable expiration reminders" />
    <ComboBox fx:id="themeComboBox" maxWidth="280" />

    <Button text="Save Settings" onAction="#handleSaveSettings" maxWidth="280" />
    <Button text="Back to Pantry" onAction="#handleBackToPantry" maxWidth="280" />
</VBox>
