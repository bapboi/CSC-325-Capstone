<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartpantry.controller.MainController"
            stylesheets="@styles.css">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="topbar">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>
            <Label text="SmartPantry" styleClass="app-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Not connected"/>
            <Button text="Connect Firebase" onAction="#onChooseCredentialFile"/>
            <Button text="Refresh" onAction="#onRefresh"/>
        </HBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <Tab text="Pantry">
                <BorderPane>
                    <top>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <padding>
                                <Insets top="12" right="16" bottom="12" left="16"/>
                            </padding>
                            <TextField fx:id="nameField" promptText="Ingredient name" prefWidth="220"/>
                            <TextField fx:id="quantityField" promptText="Qty" prefWidth="70"/>
                            <TextField fx:id="unitField" promptText="Unit (g, cups, ...)" prefWidth="130"/>
                            <TextField fx:id="categoryField" promptText="Category" prefWidth="130"/>
                            <Button text="Add" onAction="#onAddIngredient"/>
                            <Button text="Delete Selected" onAction="#onDeleteSelected"/>
                        </HBox>
                    </top>
                    <center>
                        <TableView fx:id="pantryTable">
                            <columns>
                                <TableColumn fx:id="nameColumn" text="Name" prefWidth="220"/>
                                <TableColumn fx:id="quantityColumn" text="Qty" prefWidth="80"/>
                                <TableColumn fx:id="unitColumn" text="Unit" prefWidth="130"/>
                                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150"/>
                                <TableColumn fx:id="addedDateColumn" text="Added" prefWidth="120"/>
                            </columns>
                        </TableView>
                    </center>
                </BorderPane>
            </Tab>
            <Tab text="Recipes">
                <VBox spacing="10">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>
                    <Label text="Recipe suggestions, substitutions, and quick-use recipes will live here." wrapText="true"/>
                    <Label text="Hook this tab up to RecipeService / LlmService once the LLM integration is ready."
                           wrapText="true" styleClass="hint"/>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
