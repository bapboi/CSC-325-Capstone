<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartpantry.controllers.SettingsController"
            prefWidth="420"
            prefHeight="760"
            style="-fx-background-color: #F7F7F7;">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="12"
              prefHeight="110"
              style="-fx-background-color: #21634D;">

            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <StackPane onMouseClicked="#onBackToProfile"
                       style="-fx-cursor: hand;">

                <Circle radius="14"
                        style="-fx-fill: #83B394;"/>

                <Label text="←"
                       style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
            </StackPane>

            <Label text="Settings"
                   style="-fx-font-size: 24px;
                          -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent;
                           -fx-background: transparent;">

            <VBox spacing="18"
                  style="-fx-background-color: #F7F7F7;">

                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <Label text="ACCOUNT"
                       style="-fx-font-size: 11px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #777777;"/>

                <VBox spacing="0"
                      style="-fx-background-color: white;
                             -fx-background-radius: 18;
                             -fx-border-color: #CFCFCF;
                             -fx-border-radius: 18;">

                    <HBox alignment="CENTER_LEFT"
                          prefHeight="55"
                          onMouseClicked="#onChangePassword"
                          style="-fx-cursor: hand;">

                        <padding>
                            <Insets top="12" right="16" bottom="12" left="16"/>
                        </padding>

                        <Label text="Change Password"
                               style="-fx-font-size: 12px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #222222;"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="›"
                               style="-fx-font-size: 20px;
                  -fx-text-fill: #B0B0B0;"/>
                    </HBox>

                    <Region prefHeight="1"
                            style="-fx-background-color: #E1E1E1;"/>

                    <HBox alignment="CENTER_LEFT"
                          prefHeight="55"
                          onMouseClicked="#onDeleteAccount"
                          style="-fx-cursor: hand;">

                        <padding>
                            <Insets top="12" right="16" bottom="12" left="16"/>
                        </padding>

                        <Label text="Delete Account"
                               style="-fx-font-size: 12px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #D32F2F;"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="›"
                               style="-fx-font-size: 17px;
                                      -fx-text-fill: #A0A0A0;"/>
                    </HBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              spacing="0"
              prefHeight="72"
              style="-fx-background-color: white;
                     -fx-border-color: #E4E4E4;
                     -fx-border-width: 1 0 0 0;">

            <padding>
                <Insets top="8" right="12" bottom="8" left="12"/>
            </padding>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavPantry"
                  style="-fx-cursor: hand;">

                <Label text="⌂"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Pantry"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavRecipes"
                  style="-fx-cursor: hand;">

                <Label text="▤"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Recipes"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER"
                  prefWidth="76">

                <StackPane onMouseClicked="#onNavAdd"
                           style="-fx-cursor: hand;">

                    <Circle radius="24"
                            style="-fx-fill: #21634D;"/>

                    <Label text="+"
                           style="-fx-font-size: 28px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>
                </StackPane>
            </VBox>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavShopping"
                  style="-fx-cursor: hand;">

                <Label text="⌑"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Shopping"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavProfile"
                  style="-fx-cursor: hand;">

                <Label text="♙"
                       style="-fx-font-size: 21px;
                              -fx-text-fill: #21634D;"/>

                <Label text="Profile"
                       style="-fx-font-size: 11px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #21634D;"/>
            </VBox>

        </HBox>
    </bottom>

</BorderPane>