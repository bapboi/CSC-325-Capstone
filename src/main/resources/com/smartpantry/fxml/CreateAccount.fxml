<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartpantry.controllers.CreateAccountController"
      prefWidth="400"
      prefHeight="700"
      spacing="0"
      style="-fx-background-color: white;">

    <!-- Header -->
    <VBox alignment="CENTER"
          spacing="8"
          prefWidth="400"
          prefHeight="210"
          style="-fx-background-color: #21634D;">

        <padding>
            <Insets top="35" right="20" bottom="25" left="20"/>
        </padding>

        <Label text="▣"
               style="-fx-font-size: 30px;
                      -fx-text-fill: white;"/>

        <Label text="SmartPantry"
               style="-fx-font-size: 30px;
                      -fx-font-weight: bold;
                      -fx-text-fill: white;"/>

        <Label text="Track, Scan, and Cook Smarter"
               style="-fx-font-size: 15px;
                      -fx-font-style: italic;
                      -fx-text-fill: #F2F2F2;"/>
    </VBox>

    <!-- Create account form -->
    <VBox alignment="TOP_CENTER"
          spacing="18"
          prefWidth="400"
          prefHeight="490">

        <padding>
            <Insets top="22" right="24" bottom="24" left="24"/>
        </padding>

        <!-- Sign In / Create Account tabs -->
        <HBox alignment="CENTER"
              prefWidth="352"
              prefHeight="44"
              spacing="0"
              style="-fx-background-color: #E2E2E2;
                     -fx-background-radius: 22;">

            <Button text="Sign In"
                    onAction="#handleBackToLogin"
                    prefWidth="176"
                    prefHeight="44"
                    focusTraversable="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #111111;
                           -fx-font-size: 15px;
                           -fx-cursor: hand;"/>

            <Button text="Create Account"
                    prefWidth="176"
                    prefHeight="44"
                    focusTraversable="false"
                    style="-fx-background-color: #21634D;
                           -fx-background-radius: 22;
                           -fx-text-fill: white;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;"/>
        </HBox>

        <Region prefHeight="12"/>

        <TextField fx:id="nameField"
                   promptText="Full name"
                   prefWidth="352"
                   maxWidth="352"
                   prefHeight="46"
                   style="-fx-background-color: white;
                          -fx-background-radius: 23;
                          -fx-border-color: #D8D8D8;
                          -fx-border-radius: 23;
                          -fx-border-width: 1;
                          -fx-padding: 0 16 0 16;
                          -fx-font-size: 15px;"/>

        <TextField fx:id="emailField"
                   promptText="Email address"
                   prefWidth="352"
                   maxWidth="352"
                   prefHeight="46"
                   style="-fx-background-color: white;
                          -fx-background-radius: 23;
                          -fx-border-color: #D8D8D8;
                          -fx-border-radius: 23;
                          -fx-border-width: 1;
                          -fx-padding: 0 16 0 16;
                          -fx-font-size: 15px;"/>

        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       prefWidth="352"
                       maxWidth="352"
                       prefHeight="46"
                       style="-fx-background-color: white;
                              -fx-background-radius: 23;
                              -fx-border-color: #D8D8D8;
                              -fx-border-radius: 23;
                              -fx-border-width: 1;
                              -fx-padding: 0 16 0 16;
                              -fx-font-size: 15px;"/>

        <Label fx:id="statusLabel"
               text=""
               wrapText="true"
               alignment="CENTER"
               prefWidth="352"
               minHeight="20"
               style="-fx-font-size: 13px;
                      -fx-text-fill: #A83232;"/>

        <Region prefHeight="4"/>

        <Button text="Create Account"
                onAction="#handleCreateAccount"
                prefWidth="352"
                maxWidth="352"
                prefHeight="46"
                focusTraversable="false"
                style="-fx-background-color: #21634D;
                       -fx-background-radius: 23;
                       -fx-text-fill: white;
                       -fx-font-size: 16px;
                       -fx-font-weight: bold;
                       -fx-cursor: hand;"/>
    </VBox>

</VBox>
