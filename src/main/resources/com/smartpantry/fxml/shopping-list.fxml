<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER"
      spacing="0"
      prefWidth="390"
      prefHeight="844"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml">

    <VBox alignment="CENTER_LEFT"
          spacing="6"
          prefHeight="120"
          prefWidth="390"
          style="-fx-background-color: #2f6b4f;">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="150">
            <Label text="Shopping List"
                   style="-fx-text-fill: white; -fx-font-size: 26px;" />

            <Button text="Clear 1"
                    style="-fx-background-color: #6f9b7d; -fx-text-fill: white;"/>
        </HBox>

        <Label text="1 of 7 items collected"
               style="-fx-text-fill: white; -fx-font-size: 12px;" />

    </VBox>

    <ScrollPane fitToWidth="true"
                prefWidth="390"
                prefHeight="660"
                style="-fx-background-color: transparent;">

        <VBox spacing="12" style="-fx-padding: 15;">

            <HBox spacing="8">
                <TextField promptText="Add an item..."
                           prefWidth="255"/>

                <Button text="Add"
                        prefWidth="65"
                        style="-fx-background-color: #2f6b4f; -fx-text-fill: white;"/>
            </HBox>

            <VBox spacing="4"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 15;
                         -fx-background-radius: 15;
                         -fx-padding: 10;">

                <Label text="○ Basil"/>
                <Label text="for Tomato Soup     1 bunch     Produce"
                       style="-fx-font-size: 11px; -fx-text-fill: gray;"/>

            </VBox>

            <VBox spacing="4"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 15;
                         -fx-background-radius: 15;
                         -fx-padding: 10;">

                <Label text="○ Heavy Cream"/>
                <Label text="for Tomato Soup     200 ml     Dairy"
                       style="-fx-font-size: 11px; -fx-text-fill: gray;"/>

            </VBox>

            <VBox spacing="4"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 15;
                         -fx-background-radius: 15;
                         -fx-padding: 10;">

                <Label text="○ Chicken Broth"/>
                <Label text="for Risotto     750 ml     Pantry"
                       style="-fx-font-size: 11px; -fx-text-fill: gray;"/>

            </VBox>

            <VBox spacing="4"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 15;
                         -fx-background-radius: 15;
                         -fx-padding: 10;">

                <Label text="○ Olive Oil"/>
                <Label text="1 bottle     Pantry"
                       style="-fx-font-size: 11px; -fx-text-fill: gray;"/>

            </VBox>

            <VBox spacing="4"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 15;
                         -fx-background-radius: 15;
                         -fx-padding: 10;">

                <Label text="✓ Parmesan"/>
                <Label text="100g     Dairy"
                       style="-fx-font-size: 11px; -fx-text-fill: gray;"/>

            </VBox>

            <VBox spacing="4"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 15;
                         -fx-background-radius: 15;
                         -fx-padding: 10;">

                <Label text="○ Lemons"/>
                <Label text="3     Produce"
                       style="-fx-font-size: 11px; -fx-text-fill: gray;"/>

            </VBox>

            <VBox spacing="4"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 15;
                         -fx-background-radius: 15;
                         -fx-padding: 10;">

                <Label text="○ Greek Yogurt"/>
                <Label text="400g     Dairy"
                       style="-fx-font-size: 11px; -fx-text-fill: gray;"/>

            </VBox>

        </VBox>

    </ScrollPane>

    <HBox alignment="CENTER" spacing="15" prefHeight="64">
        <Button text="Pantry" prefWidth="70"/>
        <Button text="Recipes" prefWidth="70"/>
        <Button text="+" prefWidth="55"
                style="-fx-background-color: #2f6b4f; -fx-text-fill: white; -fx-font-size: 20px;"/>
        <Button text="Shopping" prefWidth="80"/>
        <Button text="Profile" prefWidth="70"/>
    </HBox>

</VBox>