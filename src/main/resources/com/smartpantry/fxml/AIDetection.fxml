<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartpantry.controllers.AIDetectionController"
            prefWidth="400"
            prefHeight="700"
            style="-fx-background-color: white;">

    <!-- Header -->
    <top>
        <VBox spacing="6"
              prefHeight="110"
              style="-fx-background-color: #21634D;">

            <padding>
                <Insets top="28" right="18" bottom="18" left="18"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">

                <Button text="←"
                        onAction="#handleBackToPantry"
                        prefWidth="38"
                        prefHeight="38"
                        focusTraversable="false"
                        style="-fx-background-color: #83B394;
                               -fx-background-radius: 19;
                               -fx-text-fill: white;
                               -fx-font-size: 19px;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;"/>

                <VBox spacing="3">
                    <Label text="Ingredient Detected!"
                           style="-fx-font-size: 23px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>

                    <Label text="We think this is:"
                           style="-fx-font-size: 14px;
                                  -fx-font-style: italic;
                                  -fx-text-fill: #E8F2ED;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- Detection content -->
    <center>
        <VBox spacing="18"
              style="-fx-background-color: white;">

            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

            <!-- Detection result card -->
            <HBox prefHeight="155"
                  style="-fx-background-color: white;
                         -fx-background-radius: 28;
                         -fx-border-color: #6D8F7A;
                         -fx-border-radius: 28;
                         -fx-border-width: 1.5;">

                <!-- Photo placeholder -->
                <StackPane prefWidth="165"
                           style="-fx-background-color: #F0E5DF;
                                  -fx-background-radius: 27 0 0 27;">

                    <Label text="🍅"
                           style="-fx-font-size: 72px;"/>
                </StackPane>

                <!-- Detection information -->
                <VBox spacing="10"
                      alignment="CENTER_LEFT"
                      HBox.hgrow="ALWAYS">

                    <padding>
                        <Insets top="18" right="16" bottom="18" left="16"/>
                    </padding>

                    <Label fx:id="detectionResultLabel"
                           text="Tomato"
                           wrapText="true"
                           style="-fx-font-size: 20px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #111111;"/>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Confidence"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #888888;"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="95%"
                               style="-fx-font-size: 12px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #416E50;"/>
                    </HBox>

                    <Label text="Vegetables"
                           style="-fx-background-color: #DDECE6;
                                  -fx-background-radius: 15;
                                  -fx-padding: 6 12 6 12;
                                  -fx-font-size: 12px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #416E50;"/>
                </VBox>
            </HBox>

            <!-- Ingredient information -->
            <VBox spacing="0"
                  style="-fx-background-color: white;
                         -fx-background-radius: 28;
                         -fx-border-color: #6D8F7A;
                         -fx-border-radius: 28;
                         -fx-border-width: 1.5;">

                <HBox alignment="CENTER_LEFT"
                      prefHeight="70">

                    <padding>
                        <Insets top="14" right="18" bottom="14" left="18"/>
                    </padding>

                    <Label text="Quantity"
                           style="-fx-font-size: 14px;
                                  -fx-font-weight: bold;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="2"
                           style="-fx-background-color: white;
                                  -fx-background-radius: 14;
                                  -fx-border-color: #999999;
                                  -fx-border-radius: 14;
                                  -fx-padding: 4 20 4 20;
                                  -fx-font-size: 13px;"/>
                </HBox>

                <Region prefHeight="1"
                        style="-fx-background-color: #DDDDDD;"/>

                <HBox alignment="CENTER_LEFT"
                      prefHeight="70">

                    <padding>
                        <Insets top="14" right="18" bottom="14" left="18"/>
                    </padding>

                    <Label text="Category"
                           style="-fx-font-size: 14px;
                                  -fx-font-weight: bold;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="Vegetables"
                           style="-fx-background-color: white;
                                  -fx-background-radius: 14;
                                  -fx-border-color: #999999;
                                  -fx-border-radius: 14;
                                  -fx-padding: 4 14 4 14;
                                  -fx-font-size: 13px;"/>
                </HBox>
            </VBox>

            <Region prefHeight="4"/>

            <Button text="Run Sample Detection"
                    onAction="#handleRunDetection"
                    maxWidth="Infinity"
                    prefHeight="48"
                    focusTraversable="false"
                    style="-fx-background-color: #DDECE6;
                           -fx-background-radius: 24;
                           -fx-text-fill: #315F4E;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;"/>

            <Button text="Save to Pantry"
                    onAction="#handleAddDetectedItems"
                    maxWidth="Infinity"
                    prefHeight="48"
                    focusTraversable="false"
                    style="-fx-background-color: #416E50;
                           -fx-background-radius: 24;
                           -fx-text-fill: white;
                           -fx-font-size: 16px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;"/>

            <Button text="Retake Photo"
                    onAction="#handleBackToPantry"
                    maxWidth="Infinity"
                    prefHeight="48"
                    focusTraversable="false"
                    style="-fx-background-color: white;
                           -fx-background-radius: 24;
                           -fx-border-color: #777777;
                           -fx-border-radius: 24;
                           -fx-text-fill: #111111;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;"/>

        </VBox>
    </center>

</BorderPane>
