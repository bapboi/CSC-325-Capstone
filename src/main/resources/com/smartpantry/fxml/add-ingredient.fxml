<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox alignment="TOP_CENTER" spacing="16" prefWidth="390" prefHeight="844"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smartpantry.controllers.AddIngredientController"
      stylesheets="@styles.css">

    <VBox alignment="CENTER" spacing="8" prefHeight="120" prefWidth="390"
          style="-fx-background-color: #2f6b4f;">

        <Label text="Add Ingredient"
               style="-fx-text-fill: white; -fx-font-size: 28px;" />

        <Label text="Add items to your pantry"
               style="-fx-text-fill: white; -fx-font-size: 14px;" />

    </VBox>

    <HBox alignment="CENTER" spacing="10">
        <Label fx:id="statusLabel" text="" wrapText="true" maxWidth="220"/>
        <Button fx:id="connectButton" text="Connect Firebase" onAction="#onConnectFirebase" />
    </HBox>

    <Button text="Take Photo" prefWidth="300" onAction="#onChoosePhoto" />

    <Button text="Upload Image" prefWidth="300" onAction="#onChoosePhoto" />

    <Label fx:id="photoStatusTitle" text="Take Photo" style="-fx-font-weight: bold;" />
    <Label fx:id="photoStatusSubtitle" text="Tap to open camera" style="-fx-text-fill: gray; -fx-font-size: 11px;" />

    <Label text="Or enter ingredient manually" />

    <TextField fx:id="nameField" promptText="Ingredient Name" maxWidth="300" />

    <TextField fx:id="categoryField" promptText="Category" maxWidth="300" />

    <TextField fx:id="quantityField" promptText="Quantity" maxWidth="300" />

    <TextField fx:id="unitField" promptText="Unit" maxWidth="300" />

    <DatePicker fx:id="expirationDatePicker" promptText="Expiration Date" maxWidth="300" />

    <Button text="Save Ingredient" prefWidth="300" onAction="#onSave"
            style="-fx-background-color: #2f6b4f; -fx-text-fill: white;" />

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Your Pantry" style="-fx-font-weight: bold;"/>
        <Button text="Refresh" onAction="#onRefreshPantry" />
    </HBox>
    <ListView fx:id="pantryListView" prefWidth="300" prefHeight="120" />

    <Button text="Back to Pantry" prefWidth="300" onAction="#onNavPantry" />

    <HBox styleClass="nav-bar" alignment="CENTER" spacing="30">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
        <Label text="Pantry"   styleClass="nav-item" onMouseClicked="#onNavPantry"   style="-fx-cursor:hand;"/>
        <Label text="Recipes"  styleClass="nav-item" onMouseClicked="#onNavRecipes"  style="-fx-cursor:hand;"/>
        <StackPane onMouseClicked="#onNavAdd" style="-fx-cursor:hand;">
            <Circle radius="22" styleClass="nav-add-circle"/>
            <Label text="+" styleClass="nav-add-plus"/>
        </StackPane>
        <Label text="Shopping" styleClass="nav-item" onMouseClicked="#onNavShopping" style="-fx-cursor:hand;"/>
        <Label text="Profile"  styleClass="nav-item" onMouseClicked="#onNavProfile"  style="-fx-cursor:hand;"/>
    </HBox>

</VBox>
