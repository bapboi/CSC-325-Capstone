<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="22" prefWidth="390" prefHeight="844"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml">

    <VBox alignment="CENTER" spacing="8" prefHeight="140" prefWidth="390"
          style="-fx-background-color: #2f6b4f;">

        <Label text="Add Ingredient"
               style="-fx-text-fill: white; -fx-font-size: 28px;" />

        <Label text="Add items to your pantry"
               style="-fx-text-fill: white; -fx-font-size: 14px;" />

    </VBox>

    <Button text="Take Photo" prefWidth="300" />

    <Button text="Upload Image" prefWidth="300" />

    <Label text="Or enter ingredient manually" />

    <TextField promptText="Ingredient Name" maxWidth="300" />

    <TextField promptText="Category" maxWidth="300" />

    <TextField promptText="Quantity" maxWidth="300" />

    <TextField promptText="Unit" maxWidth="300" />

    <Button text="Save Ingredient" prefWidth="300"
            style="-fx-background-color: #2f6b4f; -fx-text-fill: white;" />

    <Button text="Back to Pantry" prefWidth="300" />

</VBox>
