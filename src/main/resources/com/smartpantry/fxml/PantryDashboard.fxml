<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpantry.controllers.PantryDashboardController"
            stylesheets="@styles.css"
            prefWidth="420"
            prefHeight="760">
    <top>
        <VBox styleClass="header" spacing="4">
            <Label fx:id="userLabel" text="Pantry" styleClass="header-title"/>
            <Label fx:id="statusLabel" text="" styleClass="header-subtitle"/>
            <Label fx:id="statsLabel" text="" styleClass="header-subtitle"/>
        </VBox>
    </top>
    <center>
        <VBox spacing="10">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
            <HBox spacing="8">
                <Button text="Refresh" onAction="#onRefresh"/>
                <Button text="Delete Selected" onAction="#onDelete"/>
            </HBox>
            <ListView fx:id="pantryListView" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              spacing="0"
              prefHeight="72"
              style="-fx-background-color: white;
                     -fx-border-color: #E4E4E4;
                     -fx-border-width: 1 0 0 0;">

            <padding>
                <Insets top="8" right="12" bottom="8" left="12"/>
            </padding>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavPantry"
                  style="-fx-cursor: hand;">

                <Label text="⌂"
                       alignment="CENTER"
                       prefWidth="28"
                       prefHeight="28"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #21634D;"/>

                <Label text="Pantry"
                       style="-fx-font-size: 11px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #21634D;"/>

            </VBox>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavRecipes"
                  style="-fx-cursor: hand;">

                <Label text="▤"
                       alignment="CENTER"
                       prefWidth="28"
                       prefHeight="28"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Recipes"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER"
                  prefWidth="76">

                <StackPane onMouseClicked="#onNavAdd"
                           style="-fx-cursor: hand;">

                    <Circle radius="24"
                            style="-fx-fill: #21634D;"/>

                    <Label text="+"
                           style="-fx-font-size: 28px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>
                </StackPane>
            </VBox>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavShopping"
                  style="-fx-cursor: hand;">

                <Label text="☑"
                       alignment="CENTER"
                       prefWidth="26"
                       prefHeight="26"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Shopping"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavProfile"
                  style="-fx-cursor: hand;">

                <Label text="⚙"
                       alignment="CENTER"
                       prefWidth="28"
                       prefHeight="28"
                       translateY="-2"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Profile"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>
