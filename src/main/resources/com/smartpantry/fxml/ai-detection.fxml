<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="25" prefWidth="390" prefHeight="844"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml">

    <VBox alignment="CENTER" spacing="8" prefHeight="140" prefWidth="390"
          style="-fx-background-color: #2f6b4f;">

        <Label text="AI Detection"
               style="-fx-text-fill: white; -fx-font-size: 28px;" />

        <Label text="Review detected ingredient"
               style="-fx-text-fill: white; -fx-font-size: 14px;" />

    </VBox>

    <Label text="Detected Ingredient"
           style="-fx-font-size: 20px;" />

    <Label text="Ingredient Name: Apple" />

    <Label text="Category: Fruit" />

    <Label text="Quantity: 1" />

    <Button text="Confirm Ingredient" prefWidth="300"
            style="-fx-background-color: #2f6b4f; -fx-text-fill: white;" />

    <Button text="Try Again" prefWidth="300" />

    <Button text="Enter Manually" prefWidth="300" />

    <Button text="Back to Pantry" prefWidth="300" />

</VBox>
