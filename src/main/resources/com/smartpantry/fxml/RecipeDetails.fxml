<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartpantry.controllers.RecipeDetailsController"
      stylesheets="@styles.css"
      alignment="TOP_CENTER"
      prefWidth="420"
      prefHeight="760"
      spacing="0"
      style="-fx-background-color: white;">

    <StackPane prefHeight="220"
               maxWidth="Infinity"
               style="-fx-background-color: #d9d9d9;">

        <ImageView fx:id="recipeImageView"
                   fitWidth="420"
                   fitHeight="220"
                   preserveRatio="false"/>

        <Label fx:id="imagePlaceholderLabel"
               text="Recipe Image"
               style="-fx-text-fill: #666666;
                      -fx-font-size: 16px;"/>

        <Button text="←"
                onAction="#handleBackToRecipes"
                StackPane.alignment="TOP_LEFT"
                style="-fx-background-color: rgba(80, 80, 80, 0.75);
                       -fx-background-radius: 25;
                       -fx-text-fill: white;
                       -fx-font-size: 18px;
                       -fx-cursor: hand;">

            <StackPane.margin>
                <Insets top="12" right="0" bottom="0" left="12"/>
            </StackPane.margin>
        </Button>

        <Button fx:id="heartButton"
                text="♡"
                onAction="#handleHeartSaveRecipe"
                StackPane.alignment="TOP_RIGHT"
                style="-fx-background-color: rgba(80, 80, 80, 0.75);
                       -fx-background-radius: 25;
                       -fx-text-fill: white;
                       -fx-font-size: 20px;
                       -fx-cursor: hand;">

            <StackPane.margin>
                <Insets top="12" right="12" bottom="0" left="0"/>
            </StackPane.margin>
        </Button>

        <VBox spacing="3"
              StackPane.alignment="BOTTOM_LEFT"
              maxHeight="-Infinity"
              maxWidth="-Infinity"
              mouseTransparent="true">

            <StackPane.margin>
                <Insets top="0" right="15" bottom="14" left="15"/>
            </StackPane.margin>

            <Label fx:id="recipeNameLabel"
                   text="Recipe Name"
                   wrapText="true"
                   style="-fx-text-fill: white;
                          -fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-effect: dropshadow(gaussian, black, 4, 0.6, 0, 1);"/>

            <HBox spacing="10">

                <Label fx:id="cookTimeLabel"
                       text="Cook time: N/A"
                       style="-fx-text-fill: white;
                              -fx-font-size: 11px;
                              -fx-font-weight: bold;
                              -fx-effect: dropshadow(gaussian, black, 4, 0.6, 0, 1);"/>

                <Label fx:id="difficultyLabel"
                       text="Difficulty: N/A"
                       style="-fx-text-fill: white;
                              -fx-font-size: 11px;
                              -fx-font-weight: bold;
                              -fx-effect: dropshadow(gaussian, black, 4, 0.6, 0, 1);"/>

                <Label fx:id="servingsLabel"
                       text="Servings: N/A"
                       style="-fx-text-fill: white;
                              -fx-font-size: 11px;
                              -fx-font-weight: bold;
                              -fx-effect: dropshadow(gaussian, black, 4, 0.6, 0, 1);"/>

            </HBox>
        </VBox>
    </StackPane>

    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent;
                       -fx-background: transparent;">

        <VBox spacing="0"
              style="-fx-background-color: white;">

            <VBox spacing="6"
                  style="-fx-background-color: #eef8f1;
                         -fx-padding: 12 16 12 16;">

                <Label fx:id="pantryMatchLabel"
                       text="✓ 0% pantry match"
                       maxWidth="Infinity"
                       style="-fx-background-color: #dcefe4;
                              -fx-background-radius: 18;
                              -fx-padding: 7 12 7 12;
                              -fx-text-fill: #2f6b4f;
                              -fx-font-size: 12px;
                              -fx-font-weight: bold;"/>

                <ProgressBar fx:id="pantryMatchProgressBar"
                             progress="0"
                             maxWidth="Infinity"
                             prefHeight="6"/>
            </VBox>

            <HBox alignment="CENTER"
                  spacing="0"
                  prefHeight="48"
                  style="-fx-background-color: white;
                         -fx-border-color: transparent transparent #dddddd transparent;">

                <Label fx:id="ingredientsTabLabel"
                       text="Ingredients"
                       alignment="CENTER"
                       prefWidth="210"
                       prefHeight="48"
                       onMouseClicked="#showIngredientsTab"
                       style="-fx-text-fill: #2f6b4f;
                              -fx-font-size: 12px;
                              -fx-font-weight: bold;
                              -fx-border-color: transparent transparent #2f6b4f transparent;
                              -fx-border-width: 0 0 2 0;
                              -fx-cursor: hand;"/>

                <Label fx:id="instructionsTabLabel"
                       text="Instructions"
                       alignment="CENTER"
                       prefWidth="210"
                       prefHeight="48"
                       onMouseClicked="#showInstructionsTab"
                       style="-fx-text-fill: #333333;
                              -fx-font-size: 12px;
                              -fx-font-weight: bold;
                              -fx-cursor: hand;"/>

            </HBox>

            <VBox spacing="18">

                <padding>
                    <Insets top="15" right="16" bottom="20" left="16"/>
                </padding>

                <VBox fx:id="ingredientsContent"
                      spacing="18">

                    <VBox spacing="7">

                        <Label text="YOU HAVE"
                               style="-fx-text-fill: #2f6b4f;
                                      -fx-font-size: 11px;
                                      -fx-font-weight: bold;"/>

                        <ListView fx:id="availableIngredientsListView"
                                  prefHeight="145"
                                  maxWidth="Infinity"/>

                    </VBox>

                    <VBox spacing="7">

                        <Label text="MISSING"
                               style="-fx-text-fill: #a66a00;
                                      -fx-font-size: 11px;
                                      -fx-font-weight: bold;"/>

                        <ListView fx:id="missingIngredientsListView"
                                  prefHeight="100"
                                  maxWidth="Infinity"/>

                        <Button fx:id="addMissingButton"
                                text="Add Selected Item to Shopping List"
                                onAction="#handleAddMissingToShoppingList"
                                maxWidth="Infinity"/>

                        <Button fx:id="addAllMissingButton"
                                text="Add All Missing Ingredients to Shopping List"
                                onAction="#handleAddAllMissingToShoppingList"
                                maxWidth="Infinity"
                                style="-fx-background-color: #2f6b4f;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;"/>

                    </VBox>

                </VBox>

                <VBox fx:id="instructionsContent"
                      spacing="7"
                      visible="false"
                      managed="false">

                    <Label text="INSTRUCTIONS"
                           style="-fx-text-fill: #2f6b4f;
                                  -fx-font-size: 11px;
                                  -fx-font-weight: bold;"/>

                    <TextArea fx:id="instructionsTextArea"
                              editable="false"
                              wrapText="true"
                              prefHeight="300"
                              maxWidth="Infinity"
                              promptText="Recipe instructions will appear here."/>

                </VBox>

                <Label fx:id="statusLabel"
                       text=""
                       wrapText="true"
                       maxWidth="Infinity"/>

            </VBox>
        </VBox>
    </ScrollPane>

    <HBox alignment="CENTER"
          spacing="0"
          prefHeight="72"
          style="-fx-background-color: white;
                 -fx-border-color: #E4E4E4;
                 -fx-border-width: 1 0 0 0;">

        <padding>
            <Insets top="8" right="12" bottom="8" left="12"/>
        </padding>

        <VBox alignment="CENTER"
              spacing="3"
              prefWidth="76"
              onMouseClicked="#onNavPantry"
              style="-fx-cursor: hand;">

            <Label text="⌂"
                   alignment="CENTER"
                   prefWidth="28"
                   prefHeight="28"
                   style="-fx-font-size: 22px;
                          -fx-text-fill: #A5A5A5;"/>

            <Label text="Pantry"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #777777;"/>
        </VBox>

        <VBox alignment="CENTER"
              spacing="3"
              prefWidth="76"
              onMouseClicked="#onNavRecipes"
              style="-fx-cursor: hand;">

            <Label text="▤"
                   alignment="CENTER"
                   prefWidth="28"
                   prefHeight="28"
                   style="-fx-font-size: 22px;
                          -fx-text-fill: #21634D;"/>

            <Label text="Recipes"
                   style="-fx-font-size: 11px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #21634D;"/>
        </VBox>

        <VBox alignment="CENTER"
              prefWidth="76">

            <StackPane onMouseClicked="#onNavAdd"
                       style="-fx-cursor: hand;">

                <Circle radius="24"
                        style="-fx-fill: #21634D;"/>

                <Label text="+"
                       style="-fx-font-size: 28px;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
            </StackPane>
        </VBox>

        <VBox alignment="CENTER"
              spacing="3"
              prefWidth="76"
              onMouseClicked="#onNavShopping"
              style="-fx-cursor: hand;">

            <Label text="☑"
                   alignment="CENTER"
                   prefWidth="26"
                   prefHeight="26"
                   style="-fx-font-size: 22px;
                          -fx-text-fill: #A5A5A5;"/>

            <Label text="Shopping"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #777777;"/>
        </VBox>

        <VBox alignment="CENTER"
              spacing="3"
              prefWidth="76"
              onMouseClicked="#onNavProfile"
              style="-fx-cursor: hand;">

            <Label text="⚙"
                   alignment="CENTER"
                   prefWidth="28"
                   prefHeight="28"
                   translateY="-2"
                   style="-fx-font-size: 22px;
                          -fx-text-fill: #A5A5A5;"/>

            <Label text="Profile"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #777777;"/>
        </VBox>
    </HBox>

</VBox>