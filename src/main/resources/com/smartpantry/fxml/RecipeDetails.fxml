<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartpantry.controllers.RecipeDetailsController"
      prefWidth="420"
      prefHeight="760"
      spacing="12"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="recipeNameLabel"
           text="Recipe Details"
           wrapText="true"
           style="-fx-font-size: 25px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #21634D;"/>

    <HBox spacing="12">
        <Label fx:id="cookTimeLabel"
               text="Cook time: N/A"/>

        <Label fx:id="difficultyLabel"
               text="Difficulty: N/A"/>

        <Label fx:id="servingsLabel"
               text="Servings: N/A"/>
    </HBox>

    <Label fx:id="pantryMatchLabel"
           text="Pantry match: 0%"
           style="-fx-font-weight: bold;"/>

    <ProgressBar fx:id="pantryMatchProgressBar"
                 progress="0"
                 prefWidth="380"
                 maxWidth="Infinity"/>

    <Label text="Ingredients You Have"
           style="-fx-font-size: 15px;
                  -fx-font-weight: bold;"/>

    <ListView fx:id="availableIngredientsListView"
              prefHeight="110"
              VBox.vgrow="ALWAYS"/>

    <Label text="Missing Ingredients"
           style="-fx-font-size: 15px;
                  -fx-font-weight: bold;"/>

    <ListView fx:id="missingIngredientsListView"
              prefHeight="110"
              VBox.vgrow="ALWAYS"/>

    <Label text="Instructions"
           style="-fx-font-size: 15px;
                  -fx-font-weight: bold;"/>

    <TextArea fx:id="instructionsTextArea"
              editable="false"
              wrapText="true"
              prefHeight="150"
              VBox.vgrow="ALWAYS"/>

    <Label fx:id="statusLabel"
           text=""
           wrapText="true"
           minHeight="22"/>

    <Button fx:id="saveButton"
            text="Save Recipe"
            onAction="#handleSaveRecipe"
            maxWidth="Infinity"
            prefHeight="42"/>

    <Button fx:id="addMissingButton"
            text="Add Missing Items"
            onAction="#handleAddMissingToShoppingList"
            maxWidth="Infinity"
            prefHeight="42"/>

    <Button text="Back to Recipes"
            onAction="#handleBackToRecipes"
            maxWidth="Infinity"
            prefHeight="42"/>

</VBox>
