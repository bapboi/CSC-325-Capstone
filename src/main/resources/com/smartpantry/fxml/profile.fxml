<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartpantry.controllers.ProfileController"
      alignment="TOP_CENTER"
      spacing="0"
      prefWidth="390"
      prefHeight="844">

    <VBox alignment="CENTER"
          spacing="8"
          prefHeight="200"
          prefWidth="390"
          style="-fx-background-color: #2f6b4f;">

        <Label text="J"
               alignment="CENTER"
               prefWidth="70"
               prefHeight="70"
               style="-fx-background-color: #7fab8a;
                      -fx-background-radius: 40;
                      -fx-text-fill: white;
                      -fx-font-size: 28px;"/>

        <Label text="SmartPantry User"
               style="-fx-text-fill: white;
                      -fx-font-size: 20px;
                      -fx-font-weight: bold;"/>

        <Label fx:id="emailLabel"
               text="Loading email..."
               style="-fx-text-fill: white;
                      -fx-font-size: 12px;"/>

    </VBox>

    <ScrollPane fitToWidth="true"
                prefWidth="390"
                prefHeight="580"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent;">

        <VBox spacing="18"
              style="-fx-padding: 15;">

            <HBox spacing="14"
                  alignment="CENTER">

                <VBox alignment="CENTER"
                      spacing="4"
                      prefWidth="145"
                      prefHeight="65"
                      style="-fx-background-color: white;
                             -fx-border-color: lightgray;
                             -fx-border-radius: 20;
                             -fx-background-radius: 20;">

                    <Label text="12"
                           style="-fx-text-fill: #2f6b4f;
                                  -fx-font-size: 18px;
                                  -fx-font-weight: bold;"/>

                    <Label text="Ingredients"
                           style="-fx-text-fill: gray;
                                  -fx-font-size: 11px;"/>

                </VBox>

                <VBox alignment="CENTER"
                      spacing="4"
                      prefWidth="145"
                      prefHeight="65"
                      style="-fx-background-color: white;
                             -fx-border-color: lightgray;
                             -fx-border-radius: 20;
                             -fx-background-radius: 20;">

                    <Label text="3"
                           style="-fx-text-fill: #2f6b4f;
                                  -fx-font-size: 18px;
                                  -fx-font-weight: bold;"/>

                    <Label text="Saved"
                           style="-fx-text-fill: gray;
                                  -fx-font-size: 11px;"/>

                </VBox>

            </HBox>

            <Label text="ACCOUNT"
                   style="-fx-text-fill: gray;
                          -fx-font-size: 12px;"/>

            <VBox spacing="12"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 18;
                         -fx-background-radius: 18;
                         -fx-padding: 14;">

                <HBox spacing="15">
                    <Label text="Email"
                           style="-fx-text-fill: gray;"/>

                    <Label text="Shown above"
                           style="-fx-font-weight: bold;"/>
                </HBox>

                <HBox spacing="15">
                    <Label text="User ID"
                           style="-fx-text-fill: gray;"/>

                    <Label fx:id="uidLabel"
                           text="Loading..."
                           wrapText="true"
                           style="-fx-font-weight: bold;"/>
                </HBox>

            </VBox>

            <Label text="APP"
                   style="-fx-text-fill: gray;
                          -fx-font-size: 12px;"/>

            <VBox spacing="12"
                  style="-fx-background-color: white;
                         -fx-border-color: lightgray;
                         -fx-border-radius: 18;
                         -fx-background-radius: 18;
                         -fx-padding: 14;">

                <HBox>
                    <Label text="Settings"
                           style="-fx-text-fill: gray;"/>

                    <Label text=">"/>
                </HBox>

                <HBox>
                    <Label text="Version"
                           style="-fx-text-fill: gray;"/>

                    <Label text="1.0.0"/>
                </HBox>

            </VBox>

            <Button text="Sign Out"
                    onAction="#onSignOut"
                    prefWidth="330"
                    style="-fx-background-color: #2f6b4f;
                           -fx-text-fill: white;"/>

        </VBox>

    </ScrollPane>

    <HBox alignment="CENTER"
          spacing="15"
          prefHeight="64">

        <Button text="Pantry"
                onAction="#onNavPantry"
                prefWidth="70"/>

        <Button text="Recipes"
                onAction="#onNavRecipes"
                prefWidth="70"/>

        <Button text="+"
                onAction="#onNavAdd"
                prefWidth="55"
                style="-fx-background-color: #2f6b4f;
                       -fx-text-fill: white;
                       -fx-font-size: 20px;"/>

        <Button text="Shopping"
                onAction="#onNavShopping"
                prefWidth="80"/>

        <Button text="Profile"
                onAction="#onNavProfile"
                prefWidth="70"/>

    </HBox>

</VBox>
