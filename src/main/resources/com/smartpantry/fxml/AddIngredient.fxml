<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartpantry.controllers.AddIngredientController"
            prefWidth="420"
            prefHeight="760"
            style="-fx-background-color: white;">

    <top>
        <VBox spacing="5"
              prefHeight="105"
              style="-fx-background-color: #21634D;">

            <padding>
                <Insets top="26" right="18" bottom="18" left="18"/>
            </padding>

            <Label text="Add Ingredient"
                   style="-fx-font-size: 27px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>

            <Label text="Take or upload a photo"
                   style="-fx-font-size: 15px;
                          -fx-font-style: italic;
                          -fx-text-fill: #E8F2ED;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: white;
                           -fx-background: white;">

            <VBox spacing="18"
                  style="-fx-background-color: white;">

                <padding>
                    <Insets top="18" right="18" bottom="24" left="18"/>
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="8">

                    <Label fx:id="statusLabel"
                           text=""
                           wrapText="true"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #555555;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button fx:id="connectButton"
                            text="Connect Firebase"
                            onAction="#onConnectFirebase"
                            focusTraversable="false"
                            style="-fx-background-color: transparent;
                                   -fx-text-fill: #21634D;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;
                                   -fx-cursor: hand;"/>
                </HBox>

                <VBox alignment="CENTER"
                      spacing="10"
                      prefHeight="205"
                      onMouseClicked="#onTakePhoto"
                      style="-fx-background-color: #DDECE6;
                             -fx-background-radius: 28;
                             -fx-cursor: hand;">

                    <StackPane>
                        <Circle radius="31"
                                style="-fx-fill: transparent;
                                       -fx-stroke: #21634D;
                                       -fx-stroke-width: 3;"/>

                        <Label text="📷"
                               style="-fx-font-size: 27px;"/>
                    </StackPane>

                    <Label fx:id="photoStatusTitle"
                           text="Take Photo"
                           style="-fx-font-size: 17px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #315F4E;"/>

                    <Label fx:id="photoStatusSubtitle"
                           text="Tap to open camera"
                           style="-fx-font-size: 14px;
                                  -fx-font-style: italic;
                                  -fx-text-fill: #777777;"/>
                </VBox>

                <HBox alignment="CENTER" spacing="12">

                    <Separator HBox.hgrow="ALWAYS"/>

                    <Label text="or"
                           style="-fx-font-size: 13px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #555555;"/>

                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>

                <Button text="Upload from Library"
                        onAction="#onChoosePhoto"
                        maxWidth="Infinity"
                        prefHeight="47"
                        focusTraversable="false"
                        style="-fx-background-color: #416E50;
                               -fx-background-radius: 24;
                               -fx-text-fill: white;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;"/>

                <VBox spacing="5"
                      style="-fx-background-color: #DDECE6;
                             -fx-background-radius: 25;">

                    <padding>
                        <Insets top="13" right="16" bottom="13" left="16"/>
                    </padding>

                    <Label text="Tips for best results"
                           style="-fx-font-size: 13px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #315F4E;"/>

                    <Label text="• Make sure the ingredient is clearly visible"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #444444;"/>

                    <Label text="• Use good lighting"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #444444;"/>

                    <Label text="• Take one ingredient per photo"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #444444;"/>
                </VBox>

                <VBox spacing="9">

                    <Label text="Ingredient Details"
                           style="-fx-font-size: 16px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #315F4E;"/>

                    <TextField fx:id="nameField"
                               promptText="Ingredient name"
                               prefHeight="42"
                               style="-fx-background-color: white;
                                      -fx-background-radius: 21;
                                      -fx-border-color: #D5D5D5;
                                      -fx-border-radius: 21;
                                      -fx-padding: 0 14 0 14;"/>

                    <HBox spacing="10">

                        <TextField fx:id="quantityField"
                                   promptText="Quantity"
                                   prefHeight="42"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: white;
                                          -fx-background-radius: 21;
                                          -fx-border-color: #D5D5D5;
                                          -fx-border-radius: 21;
                                          -fx-padding: 0 14 0 14;"/>

                        <TextField fx:id="unitField"
                                   promptText="Unit"
                                   prefHeight="42"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: white;
                                          -fx-background-radius: 21;
                                          -fx-border-color: #D5D5D5;
                                          -fx-border-radius: 21;
                                          -fx-padding: 0 14 0 14;"/>
                    </HBox>

                    <TextField fx:id="categoryField"
                               promptText="Category"
                               prefHeight="42"
                               style="-fx-background-color: white;
                                      -fx-background-radius: 21;
                                      -fx-border-color: #D5D5D5;
                                      -fx-border-radius: 21;
                                      -fx-padding: 0 14 0 14;"/>

                    <DatePicker fx:id="expirationDatePicker"
                                promptText="Expiration date"
                                maxWidth="Infinity"
                                prefHeight="42"/>

                    <Button text="Add to Pantry"
                            onAction="#onSave"
                            maxWidth="Infinity"
                            prefHeight="47"
                            focusTraversable="false"
                            style="-fx-background-color: #416E50;
                                   -fx-background-radius: 24;
                                   -fx-text-fill: white;
                                   -fx-font-size: 15px;
                                   -fx-font-weight: bold;
                                   -fx-cursor: hand;"/>
                </VBox>

                <VBox spacing="8">

                    <HBox alignment="CENTER_LEFT">

                        <Label text="Your Pantry"
                               style="-fx-font-size: 15px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #315F4E;"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="Refresh"
                                onAction="#onRefreshPantry"
                                focusTraversable="false"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #21634D;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <ListView fx:id="pantryListView"
                              prefHeight="135"
                              style="-fx-background-radius: 12;
                                     -fx-border-color: #DDDDDD;
                                     -fx-border-radius: 12;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              spacing="0"
              prefHeight="72"
              style="-fx-background-color: white;
                     -fx-border-color: #E4E4E4;
                     -fx-border-width: 1 0 0 0;">

            <padding>
                <Insets top="8" right="12" bottom="8" left="12"/>
            </padding>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavPantry"
                  style="-fx-cursor: hand;">

                <Label text="⌂"
                       alignment="CENTER"
                       prefWidth="28"
                       prefHeight="28"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Pantry"
                       style="-fx-font-size: 11px;
              -fx-text-fill: #777777;"/>

            </VBox>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavRecipes"
                  style="-fx-cursor: hand;">

                <Label text="▤"
                       alignment="CENTER"
                       prefWidth="28"
                       prefHeight="28"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Recipes"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER"
                  prefWidth="76">

                <StackPane onMouseClicked="#onNavAdd"
                           style="-fx-cursor: hand;">

                    <Circle radius="24"
                            style="-fx-fill: #21634D;"/>

                    <Label text="+"
                           style="-fx-font-size: 28px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>
                </StackPane>
            </VBox>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavShopping"
                  style="-fx-cursor: hand;">

                <Label text="☑"
                       alignment="CENTER"
                       prefWidth="26"
                       prefHeight="26"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Shopping"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER"
                  spacing="3"
                  prefWidth="76"
                  onMouseClicked="#onNavProfile"
                  style="-fx-cursor: hand;">

                <Label text="⚙"
                       alignment="CENTER"
                       prefWidth="28"
                       prefHeight="28"
                       translateY="-2"
                       style="-fx-font-size: 22px;
                              -fx-text-fill: #A5A5A5;"/>

                <Label text="Profile"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #777777;"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>
