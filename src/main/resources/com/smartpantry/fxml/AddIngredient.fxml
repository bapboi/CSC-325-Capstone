<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="14" prefWidth="400" prefHeight="700"
      style="-fx-background-color: #f5f7f3;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smartpantry.controllers.AddIngredientController">
    <padding>
        <Insets top="35" right="30" bottom="35" left="30" />
    </padding>

    <Label text="Add Ingredient" style="-fx-font-size: 26px; -fx-font-weight: bold;" />
    <TextField fx:id="ingredientNameField" promptText="Ingredient name" maxWidth="280" />
    <TextField fx:id="quantityField" promptText="Quantity, e.g. 2 lb" maxWidth="280" />
    <ComboBox fx:id="categoryComboBox" maxWidth="280" />
    <Label fx:id="statusLabel" wrapText="true" />

    <Button text="Add Ingredient" onAction="#handleAddIngredient" maxWidth="280" />
    <Button text="Back to Pantry" onAction="#handleBackToPantry" maxWidth="280" />
</VBox>
