<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpantry.controllers.ShoppingListController"
            stylesheets="@styles.css"
            prefWidth="420" prefHeight="760">
    <top>
        <VBox styleClass="header" spacing="4">
            <Label text="Shopping List" styleClass="header-title"/>
            <Label fx:id="statusLabel" text="" styleClass="header-subtitle"/>
        </VBox>
    </top>
    <center>
        <VBox spacing="10">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

            <!-- Add row -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="nameField"     promptText="Item name"  HBox.hgrow="ALWAYS"/>
                <TextField fx:id="quantityField" promptText="Qty"        prefWidth="55"/>
                <TextField fx:id="unitField"     promptText="Unit"       prefWidth="65"/>
                <Button text="Add" onAction="#onAdd"/>
            </HBox>

            <ListView fx:id="listView" VBox.vgrow="ALWAYS"/>

            <HBox spacing="8">
                <Button text="✓ Toggle Checked" onAction="#onToggleChecked"/>
                <Button text="→ Move to Pantry" onAction="#onMoveToPantry"/>
                <Button text="Delete"            onAction="#onDelete"/>
                <Button text="Refresh"           onAction="#onRefresh"/>
            </HBox>
        </VBox>
    </center>
    <bottom>
        <HBox xmlns="http://javafx.com/javafx/21" styleClass="nav-bar" alignment="CENTER" spacing="30">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Label text="Pantry"   styleClass="nav-item" onMouseClicked="#onNavPantry"   style="-fx-cursor:hand;"/>
            <Label text="Recipes"  styleClass="nav-item" onMouseClicked="#onNavRecipes"  style="-fx-cursor:hand;"/>
            <StackPane onMouseClicked="#onNavAdd" style="-fx-cursor:hand;">
                <Circle radius="22" styleClass="nav-add-circle"/>
                <Label text="+" styleClass="nav-add-plus"/>
            </StackPane>
            <Label text="Shopping" styleClass="nav-item" onMouseClicked="#onNavShopping" style="-fx-cursor:hand;"/>
            <Label text="Profile"  styleClass="nav-item" onMouseClicked="#onNavProfile"  style="-fx-cursor:hand;"/>
        </HBox>
    </bottom>
</BorderPane>