<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.smartpantry.controllers.RecipeSuggestionController"
            prefWidth="420" prefHeight="760"
            style="-fx-background-color: #f5f7f3;">

    <top>

        <VBox style="-fx-background-color: #2f6b4f;" spacing="4">
            <padding><Insets top="24" right="20" bottom="16" left="20"/></padding>
            <Label text="Recipe Suggestions"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Based on what's in your pantry"
                   style="-fx-font-size: 13px; -fx-text-fill: #c8ddd0;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="8">
            <padding><Insets top="12" right="14" bottom="8" left="14"/></padding>

            <!-- Controls row -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button fx:id="findButton" text="Find Recipes"
                        onAction="#onFindRecipe"
                        style="-fx-background-color: #2f6b4f; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button fx:id="clearCacheButton" text="Clear Cache"
                        onAction="#onClearCache"
                        style="-fx-font-size: 11px;"/>
                <ProgressIndicator fx:id="progressIndicator" maxWidth="22" maxHeight="22"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="cacheLabel" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-style: italic;"/>
            </HBox>

            <Label fx:id="statusLabel" text="" wrapText="true"/>

            <ListView fx:id="recipeListView" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>

            <Button fx:id="loadMoreButton" text="Load 5 More Recipes"
                    onAction="#onLoadMore"
                    maxWidth="Infinity"
                    style="-fx-background-color: #e8f0ea; -fx-text-fill: #2f6b4f; -fx-font-weight: bold;"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="15" prefHeight="64"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0e0 transparent transparent transparent;
                     -fx-border-width: 1 0 0 0;">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
            <Button text="Pantry"   prefWidth="70"  onAction="#onNavPantry"/>
            <Button text="Recipes"  prefWidth="70"
                    style="-fx-font-weight: bold;"/>
            <Button text="+"        prefWidth="55"  onAction="#onNavAdd"
                    style="-fx-background-color: #2f6b4f; -fx-text-fill: white; -fx-font-size: 20px;"/>
            <Button text="Shopping" prefWidth="80"  onAction="#onNavShopping"/>
            <Button text="Profile"  prefWidth="70"  onAction="#onNavProfile"/>
        </HBox>
    </bottom>
</BorderPane>
