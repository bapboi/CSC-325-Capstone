<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartpantry.controllers.RecipeSuggestionController"
            prefWidth="420"
            prefHeight="760"
            style="-fx-background-color: #F6F7F5;">

    <top>
        <VBox prefHeight="104"
              spacing="4"
              style="-fx-background-color: #2F6B4F;">

            <padding>
                <Insets top="18" right="20" bottom="14" left="20"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="3">
                    <Label text="Recipes"
                           style="-fx-font-size: 27px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>

                    <Label text="Based on your pantry"
                           style="-fx-font-size: 13px;
                                  -fx-font-style: italic;
                                  -fx-text-fill: #D5E6DC;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <StackPane onMouseClicked="#onNavSavedRecipes"
                           style="-fx-cursor: hand;">
                    <Circle radius="21"
                            style="-fx-fill: rgba(255,255,255,0.18);
                                   -fx-stroke: rgba(255,255,255,0.50);
                                   -fx-stroke-width: 1;"/>
                    <Label text="♡"
                           translateY="-1"
                           style="-fx-font-size: 22px;
                                  -fx-text-fill: white;"/>
                </StackPane>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="8">
            <padding>
                <Insets top="8" right="10" bottom="8" left="10"/>
            </padding>

            <HBox alignment="CENTER_LEFT"
                  spacing="8">

                <Button fx:id="findButton"
                        text="Find Recipes"
                        onAction="#onFindRecipe"
                        prefHeight="36"
                        style="-fx-background-color: #2F6B4F;
                               -fx-background-radius: 18;
                               -fx-text-fill: white;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-padding: 0 18;
                               -fx-cursor: hand;"/>

                <Button fx:id="clearCacheButton"
                        text="Clear Cache"
                        onAction="#onClearCache"
                        visible="false"
                        managed="false"/>

                <ProgressIndicator fx:id="progressIndicator"
                                   maxWidth="22"
                                   maxHeight="22"
                                   prefWidth="22"
                                   prefHeight="22"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="cacheLabel"
                       text=""
                       style="-fx-font-size: 10px;
                              -fx-text-fill: #7D8982;
                              -fx-font-style: italic;"/>
            </HBox>

            <Label fx:id="statusLabel"
                   text=""
                   wrapText="true"
                   minHeight="16"
                   maxWidth="Infinity"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #66736C;
                          -fx-padding: 0 2 0 2;"/>

            <ListView fx:id="recipeListView"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent;
                             -fx-background: transparent;
                             -fx-border-color: transparent;
                             -fx-padding: 0;"/>

            <Button fx:id="loadMoreButton"
                    text="Load 5 More Recipes"
                    onAction="#onLoadMore"
                    maxWidth="Infinity"
                    prefHeight="38"
                    style="-fx-background-color: #E7F0EA;
                           -fx-background-radius: 19;
                           -fx-border-color: #D4E1D8;
                           -fx-border-radius: 19;
                           -fx-text-fill: #2F6B4F;
                           -fx-font-size: 12px;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              spacing="0"
              prefHeight="72"
              style="-fx-background-color: white;
                     -fx-border-color: #E4E4E4;
                     -fx-border-width: 1 0 0 0;">

            <padding>
                <Insets top="8" right="12" bottom="8" left="12"/>
            </padding>

            <VBox alignment="CENTER" spacing="3" prefWidth="76"
                  onMouseClicked="#onNavPantry" style="-fx-cursor: hand;">
                <Label text="⌂" alignment="CENTER" prefWidth="28" prefHeight="28"
                       style="-fx-font-size: 22px; -fx-text-fill: #A5A5A5;"/>
                <Label text="Pantry" style="-fx-font-size: 11px; -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="3" prefWidth="76"
                  onMouseClicked="#onNavRecipes" style="-fx-cursor: hand;">
                <Label text="▤" alignment="CENTER" prefWidth="28" prefHeight="28"
                       style="-fx-font-size: 22px; -fx-text-fill: #21634D;"/>
                <Label text="Recipes"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #21634D;"/>
            </VBox>

            <VBox alignment="CENTER" prefWidth="76">
                <StackPane onMouseClicked="#onNavAdd" style="-fx-cursor: hand;">
                    <Circle radius="24" style="-fx-fill: #21634D;"/>
                    <Label text="+" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </StackPane>
            </VBox>

            <VBox alignment="CENTER" spacing="3" prefWidth="76"
                  onMouseClicked="#onNavShopping" style="-fx-cursor: hand;">
                <Label text="☑" alignment="CENTER" prefWidth="26" prefHeight="26"
                       style="-fx-font-size: 22px; -fx-text-fill: #A5A5A5;"/>
                <Label text="Shopping" style="-fx-font-size: 11px; -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="3" prefWidth="76"
                  onMouseClicked="#onNavProfile" style="-fx-cursor: hand;">
                <Label text="⚙" alignment="CENTER" prefWidth="28" prefHeight="28" translateY="-2"
                       style="-fx-font-size: 22px; -fx-text-fill: #A5A5A5;"/>
                <Label text="Profile" style="-fx-font-size: 11px; -fx-text-fill: #777777;"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>
