<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smartpantry.controllers.RecipeSuggestionController"
      spacing="14"
      prefWidth="420" prefHeight="760">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Button text="Back to Pantry" onAction="#onBackToPantry"/>

    <Label text="Find a Recipe" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <Label text="Searches the web for a recipe using what's currently in your pantry." wrapText="true"/>

    <Button fx:id="findButton" text="Find a Recipe" onAction="#onFindRecipe"/>
    <ProgressIndicator fx:id="progressIndicator" maxWidth="30" maxHeight="30"/>

    <Label fx:id="statusLabel" text="" wrapText="true"/>
    <Label fx:id="resultLabel" text="" wrapText="true"/>
    <Hyperlink fx:id="resultLink" text="" onAction="#onOpenLink"/>
</VBox>
