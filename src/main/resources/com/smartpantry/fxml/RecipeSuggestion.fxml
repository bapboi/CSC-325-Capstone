<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartpantry.controllers.RecipeSuggestionController"
            prefWidth="420"
            prefHeight="760"
            style="-fx-background-color: #f5f7f3;">

    <top>
        <VBox style="-fx-background-color: #2f6b4f;" spacing="4">
            <padding><Insets top="24" right="20" bottom="16" left="20"/></padding>
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Recipes"
                           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Based on your pantry"
                           style="-fx-font-size: 13px; -fx-font-style: italic; -fx-text-fill: #c8ddd0;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <StackPane onMouseClicked="#onNavSavedRecipes" style="-fx-cursor: hand;">
                    <Circle radius="20" style="-fx-fill: rgba(255,255,255,0.15);"/>
                    <Label text="♡" style="-fx-font-size: 20px; -fx-text-fill: white;"/>
                </StackPane>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="8">
            <padding><Insets top="12" right="14" bottom="8" left="14"/></padding>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button fx:id="findButton" text="Find Recipes"
                        onAction="#onFindRecipe"
                        style="-fx-background-color: #2f6b4f; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button fx:id="clearCacheButton" text="Clear Cache"
                        onAction="#onClearCache"
                        style="-fx-font-size: 11px;"/>
                <ProgressIndicator fx:id="progressIndicator" maxWidth="22" maxHeight="22"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="cacheLabel" text=""
                       style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-style: italic;"/>
            </HBox>

            <Label fx:id="statusLabel" text="" wrapText="true"/>

            <ListView fx:id="recipeListView" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-border-color: transparent;"/>

            <Button fx:id="loadMoreButton" text="Load 5 More Recipes"
                    onAction="#onLoadMore"
                    maxWidth="Infinity"
                    style="-fx-background-color: #e8f0ea; -fx-text-fill: #2f6b4f; -fx-font-weight: bold;"/>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              spacing="0"
              prefHeight="72"
              style="-fx-background-color: white;
                     -fx-border-color: #E4E4E4;
                     -fx-border-width: 1 0 0 0;">

            <padding>
                <Insets top="8" right="12" bottom="8" left="12"/>
            </padding>

            <VBox alignment="CENTER" spacing="3" prefWidth="76"
                  onMouseClicked="#onNavPantry" style="-fx-cursor: hand;">
                <Label text="⌂" alignment="CENTER" prefWidth="28" prefHeight="28"
                       style="-fx-font-size: 22px; -fx-text-fill: #A5A5A5;"/>
                <Label text="Pantry" style="-fx-font-size: 11px; -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="3" prefWidth="76"
                  onMouseClicked="#onNavRecipes" style="-fx-cursor: hand;">
                <Label text="▤" alignment="CENTER" prefWidth="28" prefHeight="28"
                       style="-fx-font-size: 22px; -fx-text-fill: #21634D;"/>
                <Label text="Recipes"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #21634D;"/>
            </VBox>

            <VBox alignment="CENTER" prefWidth="76">
                <StackPane onMouseClicked="#onNavAdd" style="-fx-cursor: hand;">
                    <Circle radius="24" style="-fx-fill: #21634D;"/>
                    <Label text="+" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </StackPane>
            </VBox>

            <VBox alignment="CENTER" spacing="3" prefWidth="76"
                  onMouseClicked="#onNavShopping" style="-fx-cursor: hand;">
                <Label text="☑" alignment="CENTER" prefWidth="26" prefHeight="26"
                       style="-fx-font-size: 22px; -fx-text-fill: #A5A5A5;"/>
                <Label text="Shopping" style="-fx-font-size: 11px; -fx-text-fill: #777777;"/>
            </VBox>

            <VBox alignment="CENTER" spacing="3" prefWidth="76"
                  onMouseClicked="#onNavProfile" style="-fx-cursor: hand;">
                <Label text="⚙" alignment="CENTER" prefWidth="28" prefHeight="28" translateY="-2"
                       style="-fx-font-size: 22px; -fx-text-fill: #A5A5A5;"/>
                <Label text="Profile" style="-fx-font-size: 11px; -fx-text-fill: #777777;"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>
