<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="18" prefWidth="390" prefHeight="844"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml">

    <VBox alignment="CENTER" spacing="8" prefHeight="140" prefWidth="390"
          style="-fx-background-color: #2f6b4f;">

        <Label text="My Pantry"
               style="-fx-text-fill: white; -fx-font-size: 28px;" />

        <Label text="View and manage your ingredients"
               style="-fx-text-fill: white; -fx-font-size: 14px;" />

    </VBox>

    <TextField promptText="Search pantry items" maxWidth="320" />

    <ListView prefWidth="320" prefHeight="430" />

    <Button text="Add Ingredient" prefWidth="320"
            style="-fx-background-color: #2f6b4f; -fx-text-fill: white;" />

    <HBox alignment="CENTER" spacing="15">
        <Button text="Pantry" prefWidth="90" />
        <Button text="Recipes" prefWidth="90" />
        <Button text="Account" prefWidth="90" />
    </HBox>

</VBox>
