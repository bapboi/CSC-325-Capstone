<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="22" prefWidth="390" prefHeight="844"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml">

    <VBox alignment="CENTER" spacing="10" prefHeight="180" prefWidth="390"
          style="-fx-background-color: #2f6b4f;">

        <Label text="Create Account"
               style="-fx-text-fill: white; -fx-font-size: 28px;" />

        <Label text="Start using SmartPantry"
               style="-fx-text-fill: white; -fx-font-size: 14px;" />

    </VBox>

    <TextField promptText="Full Name" maxWidth="300" />

    <TextField promptText="Email" maxWidth="300" />

    <PasswordField promptText="Password" maxWidth="300" />

    <PasswordField promptText="Confirm Password" maxWidth="300" />

    <Button text="Create Account" prefWidth="300"
            style="-fx-background-color: #2f6b4f; -fx-text-fill: white;" />

    <Button text="Back to Sign In" prefWidth="300" />

</VBox>
