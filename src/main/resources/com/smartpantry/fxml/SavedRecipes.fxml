<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartpantry.controllers.SavedRecipesController"
      spacing="12"
      prefWidth="420"
      prefHeight="760"
      style="-fx-background-color: #f5f7f3;">

    <VBox spacing="12"
          VBox.vgrow="ALWAYS">

        <padding>
            <Insets top="25" right="20" bottom="15" left="20"/>
        </padding>

        <Label text="Saved Recipes"
               style="-fx-font-size: 26px;
                      -fx-font-weight: bold;"/>

        <ListView fx:id="savedRecipeListView"
                  VBox.vgrow="ALWAYS"/>

        <HBox spacing="8">
            <Button text="View"
                    onAction="#handleViewDetails"
                    prefWidth="105"/>

            <Button text="Remove"
                    onAction="#handleRemoveSavedRecipe"
                    prefWidth="105"/>

            <Button text="Back"
                    onAction="#handleBackToPantry"
                    prefWidth="105"/>
        </HBox>
    </VBox>

    <HBox alignment="CENTER"
          spacing="0"
          prefHeight="72"
          style="-fx-background-color: white;
                 -fx-border-color: #E4E4E4;
                 -fx-border-width: 1 0 0 0;">

        <padding>
            <Insets top="8" right="12" bottom="8" left="12"/>
        </padding>

        <VBox alignment="CENTER"
              spacing="3"
              prefWidth="76"
              onMouseClicked="#onNavRecipes"
              style="-fx-cursor: hand;">

            <Label text="▤"
                   alignment="CENTER"
                   prefWidth="28"
                   prefHeight="28"
                   style="-fx-font-size: 22px;
                  -fx-text-fill: #21634D;"/>

            <Label text="Recipes"
                   style="-fx-font-size: 11px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #21634D;"/>
        </VBox>

        <VBox alignment="CENTER"
              spacing="3"
              prefWidth="76"
              onMouseClicked="#onNavRecipes"
              style="-fx-cursor: hand;">

            <Label text="▤"
                   alignment="CENTER"
                   prefWidth="28"
                   prefHeight="28"
                   style="-fx-font-size: 22px;
                          -fx-text-fill: #21634D;"/>

            <Label text="Recipes"
                   style="-fx-font-size: 11px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #21634D;"/>
        </VBox>

        <VBox alignment="CENTER"
              prefWidth="76">

            <StackPane onMouseClicked="#onNavAdd"
                       style="-fx-cursor: hand;">

                <Circle radius="24"
                        style="-fx-fill: #21634D;"/>

                <Label text="+"
                       style="-fx-font-size: 28px;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
            </StackPane>
        </VBox>

        <VBox alignment="CENTER"
              spacing="3"
              prefWidth="76"
              onMouseClicked="#onNavShopping"
              style="-fx-cursor: hand;">

            <Label text="☑"
                   alignment="CENTER"
                   prefWidth="26"
                   prefHeight="26"
                   style="-fx-font-size: 22px;
                          -fx-text-fill: #A5A5A5;"/>

            <Label text="Shopping"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #777777;"/>
        </VBox>

        <VBox alignment="CENTER"
              spacing="3"
              prefWidth="76"
              onMouseClicked="#onNavProfile"
              style="-fx-cursor: hand;">

            <Label text="⚙"
                   alignment="CENTER"
                   prefWidth="28"
                   prefHeight="28"
                   translateY="-2"
                   style="-fx-font-size: 22px;
                          -fx-text-fill: #A5A5A5;"/>

            <Label text="Profile"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #777777;"/>
        </VBox>
    </HBox>

</VBox>
